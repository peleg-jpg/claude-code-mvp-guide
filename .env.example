# Supabase - Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenRouter - Get from: https://openrouter.ai/keys (free tier + pay-per-use, 100+ models)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# SerpAPI - Get from: https://serpapi.com/manage-api-key (free tier: 100 searches/month)
SERPAPI_KEY=your_serpapi_key_here
